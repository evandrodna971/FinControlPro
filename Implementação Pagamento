async def get_subscription_status(pagbrasil_subscription_id: str):
    """
    Consulta status de uma assinatura diretamente no PagBrasil
    """
    payload = {
        "secret": PAGBRASIL_SECRET,
        "pbtoken": PAGBRASIL_TOKEN,
        "subscription": pagbrasil_subscription_id
    }
    
    async with httpx.AsyncClient() as client:
        response = await client.post(
            f"{PAGBRASIL_API_URL}/api/pagstream/subscription/get",
            data=payload,  # x-www-form-urlencoded
            headers={"Content-Type": "application/x-www-form-urlencoded"}
        )
        
        if response.status_code == 200:
            data = response.json()
            # Campos importantes [citation:8]:
            # - status: código do status
            # - next_billing_date: próxima cobrança
            # - amount_brl: valor
            # - recurrences: histórico de cobranças
            return data
