4. Implementação dos Webhooks (CRÍTICO!)
Os webhooks são a espinha dorsal da sincronização. O PagBrasil notificará seu backend sobre todos os eventos importantes .

Endpoint de Webhook no FastAPI:
python
# routers/webhooks.py
from fastapi import APIRouter, Request, HTTPException
import hmac
import hashlib

router = APIRouter(prefix="/webhooks", tags=["webhooks"])

@router.post("/pagbrasil")
async def pagbrasil_webhook(request: Request):
    """
    Recebe notificações do PagBrasil sobre mudanças nas assinaturas
    """
    body = await request.body()
    headers = request.headers
    
    # VALIDAÇÃO DE SEGURANÇA: verificar se é realmente do PagBrasil
    signature = headers.get("X-PagBrasil-Signature")
    expected_signature = hmac.new(
        key=PAGBRASIL_SECRET.encode(),
        msg=body,
        digestmod=hashlib.sha256
    ).hexdigest()
    
    if signature != expected_signature:
        raise HTTPException(status_code=401, detail="Invalid signature")
    
    # Processar o evento
    data = await request.json()
    event_type = data.get("event")  # payment_confirmed, recurrence_authorized, etc.
    
    if event_type == "payment_confirmed":
        # Liberar acesso ao usuário
        await handle_payment_confirmed(data)
    
    elif event_type == "recurrence_authorized":
        # Consentimento para recorrência foi autorizado
        await handle_recurrence_authorized(data)
    
    elif event_type == "payment_failed":
        # Notificar usuário e tentar novamente
        await handle_payment_failed(data)
    
    # Responder para o PagBrasil confirmando recebimento
    return {"status": "received", "timestamp": datetime.now().isoformat()}

async def handle_payment_confirmed(data):
    """Pagamento confirmado - ativar/renovar assinatura"""
    subscription_id = data["subscription_id"]
    
    # Atualizar status no banco
    await update_subscription_status(
        subscription_id=subscription_id,
        status="active",
        next_billing_date=data["next_billing_date"]
    )
    
    # Registrar no histórico
    await create_payment_history(
        subscription_id=subscription_id,
        amount=data["amount"],
        status="paid"
    )

async def handle_payment_failed(data):
    """Pagamento falhou - tentar novamente ou notificar"""
    subscription_id = data["subscription_id"]
    
    # O PagBrasil fará até 3 retentativas em 7 dias [citation:2]
    # Você pode notificar o usuário
    await notify_user_payment_failed(subscription_id)
