import httpx
from datetime import datetime

PAGBRASIL_API_URL = "https://api.pagbrasil.com"  # ou sandbox para testes
PAGBRASIL_SECRET = "seu_secret_do_dashboard"
PAGBRASIL_TOKEN = "seu_pbtoken"

async def create_subscription_with_initial_payment(user_data, plan_data):
    """
    Cria uma assinatura com pagamento inicial + consentimento
    Documentação: https://www.pagbrasil.com/pt-br/blog/pix/api-pix-automatico-da-pagbrasil-guia-de-integracao-para-desenvolvedores/ [citation:1]
    """
    payload = {
        "secret": PAGBRASIL_SECRET,
        "pbtoken": PAGBRASIL_TOKEN,
        "customer": {
            "name": user_data["name"],
            "email": user_data["email"],
            "cpf_cnpj": user_data["cpf"],
            "phone": user_data["phone"],
            "address": user_data["address"]
        },
        "order": {
            "amount": plan_data["price"],  # Valor da primeira cobrança
            "description": f"Plano {plan_data['name']} - FinControl Pro",
            "payment_method": "pix_automatic"  # Importante!
        },
        "recurrence": {
            "frequency": "M",  # M = mensal, Q = trimestral, Y = anual
            "frequency_value": 1,
            "limit": 0,  # 0 = indefinido
            "first_charge_date": datetime.now().strftime("%Y-%m-%d")  # hoje
        }
    }
    
    async with httpx.AsyncClient() as client:
        response = await client.post(
            f"{PAGBRASIL_API_URL}/order/create",
            json=payload
        )
        return response.json()
