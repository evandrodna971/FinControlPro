// components/PixPayment.tsx
import { useState, useEffect } from 'react';
import { QRCodeSVG } from 'qrcode.react'; // ou use uma lib de QR Code

interface PixPaymentProps {
  pixImage: string;  // URL da imagem QR Code
  pixCode: string;   // código copia e cola
  onPaymentConfirmed: () => void;
}

export function PixPayment({ pixImage, pixCode, onPaymentConfirmed }: PixPaymentProps) {
  const [copied, setCopied] = useState(false);
  
  // Aguarda webhook de confirmação
  useEffect(() => {
    // Você pode usar Server-Sent Events ou polling
    // Mas o ideal é confiar no webhook + atualização via query
    const checkPayment = setInterval(() => {
      // Chamar API para verificar status
      fetch('/api/subscription/status')
        .then(res => res.json())
        .then(data => {
          if (data.status === 'active') {
            onPaymentConfirmed();
            clearInterval(checkPayment);
          }
        });
    }, 5000);
    
    return () => clearInterval(checkPayment);
  }, []);
  
  const copyToClipboard = () => {
    navigator.clipboard.writeText(pixCode);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };
  
  return (
    <div className="p-6 bg-white rounded-lg shadow-lg">
      <h3 className="text-lg font-semibold mb-4">Pagamento via Pix</h3>
      
      <div className="flex flex-col items-center">
        {/* QR Code */}
        <img src={pixImage} alt="QR Code Pix" className="w-64 h-64 mb-4" />
        
        {/* Código copia e cola */}
        <div className="w-full bg-gray-100 p-3 rounded mb-3">
          <p className="text-sm truncate">{pixCode}</p>
        </div>
        
        <button
          onClick={copyToClipboard}
          className="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700"
        >
          {copied ? 'Copiado!' : 'Copiar código'}
        </button>
        
        <p className="text-sm text-gray-500 mt-4">
          Após o pagamento, sua assinatura será ativada automaticamente.
          Você será notificado por e-mail e WhatsApp.
        </p>
      </div>
    </div>
  );
}
